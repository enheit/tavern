{
  "plugins": ["typescript", "react", "react-hooks", "import", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "rules": {
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "error"
  },
  "ignorePatterns": ["**/dist/**", "**/out/**", "**/coverage/**", "**/.wrangler/**"]
}
