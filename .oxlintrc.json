{
  "plugins": ["typescript", "react", "react-hooks", "import", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "rules": {
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "error",
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": ["error", { "allow": ["**/*.css"] }]
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/out/**",
    "**/coverage/**",
    "**/.wrangler/**",
    "**/src/paraglide/**",
    "**/src/components/ui/**"
  ]
}
