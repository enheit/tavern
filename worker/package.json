{
  "name": "@tavern/worker",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:ws": "vitest run --config vitest.config.ws.ts --max-workers=1 --no-isolate",
    "types": "wrangler types",
    "migrate:local": "wrangler d1 migrations apply tavern-db --local",
    "migrate:remote": "wrangler d1 migrations apply tavern-db --remote"
  },
  "dependencies": {
    "@tavern/shared": "workspace:*",
    "better-auth": "1.6.23",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.28",
    "music-metadata": "11.13.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@vitest/coverage-istanbul": "4.1.10",
    "drizzle-kit": "0.31.10",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
