{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tavern",
  "version": "0.1.0",
  "identifier": "app.tavern.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:app",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter tavern-app build",
    "frontendDist": "../app/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tavern",
        "width": 1200,
        "height": 760,
        "minWidth": 940,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
