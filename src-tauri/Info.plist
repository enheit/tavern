<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- S6.3: merged into the bundle's Info.plist by tauri-build. TCC prompts need these
     strings or macOS kills the process on first camera/mic access. -->
<plist version="1.0">
<dict>
  <key>NSCameraUsageDescription</key>
  <string>Tavern uses the camera for webcam video in voice channels.</string>
  <key>NSMicrophoneUsageDescription</key>
  <string>Tavern uses the microphone for voice chat.</string>
</dict>
</plist>
