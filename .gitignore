# Node / pnpm
node_modules/
dist/
coverage/

# Vitest browser-mode artifacts (failure screenshots / attachments)
.vitest-attachments/
__screenshots__/

# Rust
target/

# Cloudflare / Wrangler
.wrangler/
.dev.vars

# Tauri generated schemas/bindings
src-tauri/gen/
spikes/webcodecs/gen/

# ts-rs default output dir (S2.7): `cargo test --workspace` writes here without
# TS_RS_EXPORT_DIR. The committed protocol TS lives in worker/src/protocol +
# app/src/lib/protocol (generated via `pnpm gen:protocol`).
crates/protocol/bindings/

# Secrets / keys
*.key

# macOS
.DS_Store

# Playwright MCP scratch output
.playwright-mcp/

# Real-browser e2e artifacts (app/e2e): screenshots + generated fake-mic tone
app/e2e/screenshots/

# S1.4 encoded-frame dumps: large (~2 MB) VP8 binaries, regenerable via
# spikes/sfu/run_tap.sh; kept on disk as S1.5 decode-probe input. Sidecar
# dump_*.json (branch + frame counts) IS committed as the DoD evidence.
docs/spike-results/*.ivf
docs/spike-results/publish-tap-*.json
# S1.6 screen-capture PNGs: downscaled shots of the actual desktop (privacy) + regenerable
# via spikes/capture/screen. The screen-*.json (achieved fps) IS committed as the P4 evidence.
docs/spike-results/screen-*.png
